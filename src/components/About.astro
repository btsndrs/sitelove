---
interface Props {
  sectionLabel: string;
  headline: string;
  description: string;
}
const { sectionLabel, headline, description } = Astro.props;
---

<section class="bg-brand-mid py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="section-label">{sectionLabel}</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand mb-6 leading-tight">{headline}</h2>
      </div>
      <div>
        <p class="text-brand/60 leading-relaxed text-base">{description}</p>
      </div>
    </div>
  </div>
</section>
