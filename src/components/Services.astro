---
interface ServiceCard {
  title: string;
  deliveryTime: string;
  items: string[];
}
interface Props {
  sectionLabel: string;
  headline: string;
  subheadline: string;
  cards: ServiceCard[];
}
const { sectionLabel, headline, subheadline, cards } = Astro.props;
---

<section class="bg-brand-mid py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="mb-16">
      <span class="section-label">{sectionLabel}</span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand mb-4 max-w-2xl">{headline}</h2>
      <p class="text-brand/60 max-w-xl leading-relaxed">{subheadline}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {cards.map((card) => (
        <div class="bg-brand-light p-8 md:p-10 border border-brand/5 hover:shadow-xl transition-shadow duration-300">
          <div class="flex items-start justify-between mb-8">
            <h3 class="font-heading font-bold text-xl text-brand">{card.title}</h3>
            <span class="text-xs font-heading font-semibold tracking-widest uppercase bg-brand-accent/10 text-brand-accent px-3 py-1 ml-4 flex-shrink-0">{card.deliveryTime}</span>
          </div>
          <ul class="space-y-3">
            {card.items.map((item) => (
              <li class="checklist-item">
                <span class="text-brand-accent mt-0.5 flex-shrink-0">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
