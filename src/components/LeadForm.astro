---
interface Props {
  sectionLabel: string;
  headline: string;
  description: string;
  namePlaceholder: string;
  emailPlaceholder: string;
  ctaLabel: string;
  successMessage: string;
  errorMessage: string;
  successHref?: string;
}
const { sectionLabel, headline, description, namePlaceholder, emailPlaceholder, ctaLabel, successMessage, errorMessage, successHref = '/koszonjuk' } = Astro.props;
---

<section class="bg-brand-light py-20 md:py-28" id="download">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: text + form -->
      <div>
        <span class="section-label">{sectionLabel}</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand mb-5 max-w-lg">{headline}</h2>
        <p class="text-brand/60 leading-relaxed mb-10 max-w-md">{description}</p>

        <form
          name="sample-download"
          method="POST"
          action={successHref}
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-4 max-w-md"
          id="download-form"
        >
          <input type="hidden" name="form-name" value="sample-download" />
          <p class="hidden"><input name="bot-field" /></p>

          <input 
            type="text"
            name="name"
            placeholder={namePlaceholder}
            required
            class="w-full border border-brand/20 bg-white px-4 py-3 text-sm font-body text-brand placeholder:text-brand/30 focus:outline-none focus:border-brand-accent transition-colors"
          />
          <input 
            type="email"
            name="email"
            placeholder={emailPlaceholder}
            required
            class="w-full border border-brand/20 bg-white px-4 py-3 text-sm font-body text-brand placeholder:text-brand/30 focus:outline-none focus:border-brand-accent transition-colors"
          />
          <button type="submit" class="btn-primary w-full">{ctaLabel}</button>
        </form>

      </div>

      <!-- Right: mockup image -->
      <div class="relative flex justify-center">
        <div class="absolute inset-0 bg-brand-accent/5 -skew-x-2 scale-105"></div>
        <img 
          src="/images/mockup01.jpg"
          alt="Sample study preview"
          class="relative w-full max-w-md object-contain drop-shadow-2xl"
        />
      </div>
    </div>
  </div>
</section>

