---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Köszönjük! | QPlot by Qvarta" lang="hu">
  <main class="min-h-screen bg-brand-light flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <h1 class="font-heading text-3xl font-bold text-brand mb-4">Köszönjük!</h1>
      <p class="text-brand/70 mb-8">Az adataid megkaptuk. A mintadokumentum letöltése automatikusan elindul — ha nem, kattints az alábbi gombra.</p>
      <a
        href="/files/Megval_tanulmany-minta.pdf"
        download="Megvalosithatosagi-tanulmany-minta.pdf"
        class="btn-primary inline-block mb-6"
      >
        Letöltés
      </a>
      <br />
      <a href="/" class="text-sm text-brand/50 hover:text-brand underline">← Vissza a főoldalra</a>
    </div>
  </main>
</BaseLayout>

<script>
  // Auto-trigger download on page load
  const a = document.createElement('a');
  a.href = '/files/Megval_tanulmany-minta.pdf';
  a.download = 'Megvalosithatosagi-tanulmany-minta.pdf';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
</script>
